{
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --filter omp-flow-core build && pnpm --filter omp-flow build",
    "build:core": "pnpm --filter omp-flow-core build",
    "build:cli": "pnpm --filter omp-flow build",
    "test": "pnpm --filter omp-flow-core test && pnpm --filter omp-flow test",
    "test:core": "pnpm --filter omp-flow-core test",
    "test:cli": "pnpm --filter omp-flow test",
    "lint": "pnpm --filter omp-flow-core lint && pnpm --filter omp-flow lint",
    "typecheck": "pnpm --filter omp-flow-core build && pnpm --filter omp-flow typecheck",
    "release": "pnpm --filter omp-flow release",
    "release:minor": "pnpm --filter omp-flow release:minor",
    "release:major": "pnpm --filter omp-flow release:major",
    "release:beta": "pnpm --filter omp-flow release:beta",
    "release:rc": "pnpm --filter omp-flow release:rc",
    "release:promote": "pnpm --filter omp-flow release:promote",
    "release:check": "node packages/cli/scripts/release-preflight.js check-versions",
    "release:plan": "node packages/cli/scripts/release-preflight.js publish-plan"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  }
}
