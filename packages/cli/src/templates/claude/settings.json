{
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.py\"",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-workflow-state.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-agent-context.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-agent-context.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-python-owned.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-python-owned.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-python-owned.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "omp-flow-research",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-agent-identity.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "omp-flow-architect",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-agent-identity.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "omp-flow-qbd",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-agent-identity.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "omp-flow-implement",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-agent-identity.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "omp-flow-check",
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 \"$CLAUDE_PROJECT_DIR/.claude/hooks/inject-agent-identity.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "enabledPlugins": {}
}
