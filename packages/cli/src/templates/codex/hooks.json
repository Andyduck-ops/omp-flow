{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{PYTHON_CMD}} -X utf8 -c \"import os,pathlib,runpy,subprocess; root=os.fsdecode(subprocess.check_output(['git','rev-parse','--show-toplevel'])).strip(); runpy.run_path(str(pathlib.Path(root)/'.codex'/'hooks'/'inject-workflow-state.py'),run_name='__main__')\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
